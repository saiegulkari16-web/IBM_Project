# ============================================================
# Money Matters — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit the actual .env file.
# ============================================================

# --- IBM watsonx.ai ---
WATSONX_API_KEY=jxhk-kZB9_jl9Lbr52EQOW7-MfbTDAANN4Stv8oqIBQr
WATSONX_PROJECT_ID=ae804e2b-3ac7-41cc-9bd9-d89f5ead9e0e
WATSONX_URL=https://us-south.ml.cloud.ibm.com
# Region: Dallas (us-south) — change to eu-gb for London, jp-tok for Tokyo
IBM_REGION=us-south

# --- IBM Cloud Object Storage ---
COS_API_KEY=your_cos_api_key_here
COS_INSTANCE_CRN=your_cos_instance_crn_here
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_BUCKET_NAME=money-matters-rag

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- App Settings ---
APP_ENV=development
APP_SECRET_KEY=change_this_to_a_random_secret_key
DEBUG=True

# --- News API (optional – for Daily Brief) ---
NEWS_API_KEY=your_news_api_key_here
